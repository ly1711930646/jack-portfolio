# 腾讯云 CloudStudio 部署用 GitHub 作为图床与内容存储
# 1) 复制本文件为 .env（.env 不会被提交）
# 2) 填入你自己的值
# 3) 在 GitHub 生成一个「细粒度个人访问令牌(Fine-grained PAT)」，仅授予本仓库的 Contents: Read and write 权限，降低泄露风险
#
# 仓库名（格式：owner/name，例如 ly1711930646/jack-portfolio）
VITE_GH_REPO=ly1711930646/jack-portfolio
# 分支（默认 main）
VITE_GH_BRANCH=main
# 访问令牌（建议用细粒度 PAT，仅授权该仓库，不要用主账号永久密钥）
VITE_GH_TOKEN=your-github-pat
# 图片提交的仓库目录（保持默认即可）
VITE_GH_UPLOAD_PATH=public/assets/uploads
# content.json 在仓库中的路径（保持默认即可）
VITE_GH_CONTENT_KEY=public/data/content.json
